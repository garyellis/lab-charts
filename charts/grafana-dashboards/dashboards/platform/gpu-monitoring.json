{
  "title": "GPU Monitoring (DCGM)",
  "uid": "gpu-monitoring-dcgm",
  "description": "NVIDIA GPU health and utilization sourced from DCGM exporter (DCGM_FI_DEV_* metrics).",
  "tags": ["gpu", "dcgm", "platform"],
  "schemaVersion": 38,
  "version": 3,
  "editable": true,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "timezone": "browser",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "label": "Datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "refresh": 1
      },
      {
        "name": "Hostname",
        "type": "query",
        "label": "Hostname",
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "query": "label_values(DCGM_FI_DEV_GPU_UTIL, Hostname)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {"selected": true, "text": "All", "value": "$__all"},
        "sort": 1
      },
      {
        "name": "gpu",
        "type": "query",
        "label": "GPU",
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "query": "label_values(DCGM_FI_DEV_GPU_UTIL{Hostname=~\"$Hostname\"}, gpu)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {"selected": true, "text": "All", "value": "$__all"},
        "sort": 3
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "GPU Power Draw",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "DCGM_FI_DEV_POWER_USAGE{Hostname=~\"$Hostname\", gpu=~\"$gpu\"}",
          "legendFormat": "{{Hostname}} / GPU {{gpu}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "color": {"mode": "palette-classic"},
          "custom": {"fillOpacity": 10}
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "GPU & Memory Temperature",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 6, "w": 8, "x": 8, "y": 0},
      "targets": [
        {
          "expr": "DCGM_FI_DEV_GPU_TEMP{Hostname=~\"$Hostname\", gpu=~\"$gpu\"}",
          "legendFormat": "{{Hostname}} / GPU {{gpu}} core",
          "refId": "A"
        },
        {
          "expr": "DCGM_FI_DEV_MEMORY_TEMP{Hostname=~\"$Hostname\", gpu=~\"$gpu\"}",
          "legendFormat": "{{Hostname}} / GPU {{gpu}} mem",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "color": {"mode": "palette-classic"},
          "custom": {"fillOpacity": 10}
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "GPU Utilization",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 6, "w": 8, "x": 16, "y": 0},
      "targets": [
        {
          "expr": "DCGM_FI_DEV_GPU_UTIL{Hostname=~\"$Hostname\", gpu=~\"$gpu\"}",
          "legendFormat": "{{Hostname}} / GPU {{gpu}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 100,
          "min": 0,
          "color": {"mode": "palette-classic"},
          "custom": {"fillOpacity": 10}
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "Framebuffer Memory (Used / Free)",
      "type": "timeseries",
      "description": "DCGM reports FB memory in MiB. Divided by 1024 and displayed in gibibytes.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 6},
      "targets": [
        {
          "expr": "DCGM_FI_DEV_FB_USED{Hostname=~\"$Hostname\", gpu=~\"$gpu\"} / 1024",
          "legendFormat": "{{Hostname}} / GPU {{gpu}} used",
          "refId": "A"
        },
        {
          "expr": "DCGM_FI_DEV_FB_FREE{Hostname=~\"$Hostname\", gpu=~\"$gpu\"} / 1024",
          "legendFormat": "{{Hostname}} / GPU {{gpu}} free",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "gbytes",
          "color": {"mode": "palette-classic"},
          "custom": {"fillOpacity": 10}
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "title": "Framebuffer Utilization",
      "type": "gauge",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 6, "w": 6, "x": 12, "y": 6},
      "targets": [
        {
          "expr": "(DCGM_FI_DEV_FB_USED{Hostname=~\"$Hostname\", gpu=~\"$gpu\"} / (DCGM_FI_DEV_FB_USED{Hostname=~\"$Hostname\", gpu=~\"$gpu\"} + DCGM_FI_DEV_FB_FREE{Hostname=~\"$Hostname\", gpu=~\"$gpu\"})) * 100",
          "legendFormat": "{{Hostname}} / GPU {{gpu}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "green"},
              {"value": 70, "color": "yellow"},
              {"value": 90, "color": "red"}
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "title": "Power vs. Management Limit",
      "description": "Power draw as a percentage of DCGM_FI_DEV_POWER_MGMT_LIMIT (per-GPU TDP cap).",
      "type": "gauge",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 6, "w": 6, "x": 18, "y": 6},
      "targets": [
        {
          "expr": "(DCGM_FI_DEV_POWER_USAGE{Hostname=~\"$Hostname\", gpu=~\"$gpu\"} / DCGM_FI_DEV_POWER_MGMT_LIMIT{Hostname=~\"$Hostname\", gpu=~\"$gpu\"}) * 100",
          "legendFormat": "{{Hostname}} / GPU {{gpu}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "green"},
              {"value": 80, "color": "yellow"},
              {"value": 95, "color": "red"}
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "title": "Clock Frequencies",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 12},
      "targets": [
        {
          "expr": "DCGM_FI_DEV_SM_CLOCK{Hostname=~\"$Hostname\", gpu=~\"$gpu\"} * 1e6",
          "legendFormat": "{{Hostname}} / GPU {{gpu}} SM",
          "refId": "A"
        },
        {
          "expr": "DCGM_FI_DEV_MEM_CLOCK{Hostname=~\"$Hostname\", gpu=~\"$gpu\"} * 1e6",
          "legendFormat": "{{Hostname}} / GPU {{gpu}} memory",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "hertz",
          "decimals": 0,
          "color": {"mode": "palette-classic"},
          "custom": {"fillOpacity": 10}
        },
        "overrides": []
      }
    },
    {
      "id": 8,
      "title": "Memory Copy / Encoder / Decoder Utilization",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 12},
      "targets": [
        {
          "expr": "DCGM_FI_DEV_MEM_COPY_UTIL{Hostname=~\"$Hostname\", gpu=~\"$gpu\"}",
          "legendFormat": "{{Hostname}} / GPU {{gpu}} mem copy",
          "refId": "A"
        },
        {
          "expr": "DCGM_FI_DEV_ENC_UTIL{Hostname=~\"$Hostname\", gpu=~\"$gpu\"}",
          "legendFormat": "{{Hostname}} / GPU {{gpu}} encoder",
          "refId": "B"
        },
        {
          "expr": "DCGM_FI_DEV_DEC_UTIL{Hostname=~\"$Hostname\", gpu=~\"$gpu\"}",
          "legendFormat": "{{Hostname}} / GPU {{gpu}} decoder",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 100,
          "min": 0,
          "color": {"mode": "palette-classic"},
          "custom": {"fillOpacity": 10}
        },
        "overrides": []
      }
    },
    {
      "id": 9,
      "title": "PCIe Replay Errors (rate)",
      "description": "PCIe replay counter is monotonic; shown as increase over $__rate_interval to surface active link issues.",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 18},
      "targets": [
        {
          "expr": "increase(DCGM_FI_DEV_PCIE_REPLAY_COUNTER{Hostname=~\"$Hostname\", gpu=~\"$gpu\"}[$__rate_interval])",
          "legendFormat": "{{Hostname}} / GPU {{gpu}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "palette-classic"},
          "custom": {"fillOpacity": 10}
        },
        "overrides": []
      }
    },
    {
      "id": 10,
      "title": "XID Errors (new in window)",
      "description": "DCGM_FI_DEV_XID_ERRORS is a cumulative counter of hardware/driver XID events. Shown as increase over $__rate_interval so any non-zero value indicates a fresh event.",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 6, "w": 6, "x": 12, "y": 18},
      "targets": [
        {
          "expr": "sum by (Hostname, gpu) (increase(DCGM_FI_DEV_XID_ERRORS{Hostname=~\"$Hostname\", gpu=~\"$gpu\"}[$__rate_interval]))",
          "legendFormat": "{{Hostname}} / GPU {{gpu}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "green"},
              {"value": 1, "color": "red"}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"]},
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 11,
      "title": "Total Energy Consumed",
      "description": "DCGM_FI_DEV_TOTAL_ENERGY_CONSUMPTION is reported in mJ (millijoules), cumulative since driver load. Converted to kWh: mJ -> J (/1000) -> Wh (/3600) -> kWh (/1000) = /3.6e9.",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 6, "w": 6, "x": 18, "y": 18},
      "targets": [
        {
          "expr": "sum(DCGM_FI_DEV_TOTAL_ENERGY_CONSUMPTION{Hostname=~\"$Hostname\", gpu=~\"$gpu\"}) / 3.6e9",
          "legendFormat": "Total",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "kwatth",
          "decimals": 3,
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "green"}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"]},
        "colorMode": "value",
        "graphMode": "none"
      }
    }
  ]
}
